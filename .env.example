# ========================================
# Database Configuration
# ========================================
DATABASE_URL="postgresql://user:password@localhost:5432/arimasgym"

# ========================================
# JWT Authentication
# ========================================
# Access Token - صلاحيته قصيرة (15 دقيقة)
JWT_ACCESS_SECRET="your-super-secret-access-key-change-in-production"
JWT_ACCESS_EXPIRATION="15m"

# Refresh Token - صلاحيته طويلة (7 أيام)
JWT_REFRESH_SECRET="your-super-secret-refresh-key-change-in-production"
JWT_REFRESH_EXPIRATION="7d"

# ========================================
# Application Configuration
# ========================================
NODE_ENV="development"
PORT=3000

# API Domain (استخدم api.arimasgym.com في الإنتاج)
API_DOMAIN="http://localhost:3000"

# Frontend Domain (للـ CORS)
FRONTEND_DOMAIN="http://localhost:3000"

# ========================================
# Optional: Timezone
# ========================================
TZ="UTC"

# ========================================
# Database Seeding (npm run prisma:seed)
# ========================================
# حساب Admin الافتراضي الذي يُنشئه سكربت الـ seed
ADMIN_EMAIL="admin@arimasgym.com"
ADMIN_PASSWORD="ChangeMe123!"
ADMIN_FULL_NAME="Gym Admin"
