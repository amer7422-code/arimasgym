# انسخ هذا الملف باسم .env وعدّل القيم قبل التشغيل
PORT=3000

# مفتاح سري طويل وعشوائي لتوقيع الـ JWT - غيّره إلزامياً قبل النشر الحقيقي
JWT_SECRET=change-this-to-a-long-random-secret-string

# مدة صلاحية التوكن
JWT_EXPIRES_IN=7d

# الدومين المسموح له بالاتصال بالـ API (رابط الموقع عند نشره)
CORS_ORIGIN=*
