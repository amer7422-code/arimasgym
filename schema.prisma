// ============================================
// Gym Management System - Core Database Schema
// Prisma ORM + PostgreSQL
// ============================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============================================
// ENUMS
// ============================================

enum Role {
  ADMIN
  MEMBER
  TRAINER
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

enum PlanType {
  MONTHLY
  QUARTERLY
  YEARLY
  DAY_PASS
}

enum MembershipStatus {
  ACTIVE
  EXPIRED
  CANCELLED
  PENDING
}

// ============================================
// CORE MODELS
// ============================================

model User {
  id            String     @id @default(uuid())
  email         String     @unique
  passwordHash  String     @map("password_hash")
  role          Role       @default(MEMBER)
  status        UserStatus @default(ACTIVE)

  // حقول الملف الشخصي - اختيارية لأنها لا تُطلب وقت التسجيل (Auth Module)
  // وتُستكمل لاحقاً عبر Members Module
  fullName      String?    @map("full_name")
  phoneNumber   String?    @map("phone_number")
  birthDate     DateTime?  @map("birth_date")
  gender        String?    @map("gender")

  // Soft delete support
  deletedAt     DateTime?  @map("deleted_at")

  createdAt     DateTime   @default(now()) @map("created_at")
  updatedAt     DateTime   @updatedAt @map("updated_at")

  // Relations (1 User -> Many Memberships/Attendance/WorkoutPlans)
  memberships   Membership[]
  attendances   Attendance[]
  workoutPlans  WorkoutPlan[]

  @@index([email])
  @@index([deletedAt])
  @@map("users")
}

model Membership {
  id         String            @id @default(uuid())
  userId     String            @map("user_id")
  planType   PlanType          @map("plan_type")
  startDate  DateTime          @map("start_date")
  endDate    DateTime          @map("end_date")
  status     MembershipStatus  @default(PENDING)

  createdAt  DateTime          @default(now()) @map("created_at")
  updatedAt  DateTime          @updatedAt @map("updated_at")

  // Relation: Membership belongs to one User
  user        User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Relation: A Membership can be linked to many Attendance records
  // (كل حضور مرتبط باشتراك محدد كان فعالاً وقت الدخول)
  attendances Attendance[]

  @@index([userId])
  @@index([status])
  @@map("memberships")
}

model Attendance {
  id            String     @id @default(uuid())
  userId        String     @map("user_id")
  membershipId  String?    @map("membership_id")

  checkInTime   DateTime   @map("check_in_time")
  checkOutTime  DateTime?  @map("check_out_time")

  createdAt     DateTime   @default(now()) @map("created_at")

  // Relations
  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  membership  Membership? @relation(fields: [membershipId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([membershipId])
  @@index([checkInTime])
  @@map("attendances")
}

model WorkoutPlan {
  id         String   @id @default(uuid())
  userId     String   @map("user_id")

  // JSON مرن ليدعم أي هيكلية تمارين مستقبلية بدون تعديل الـ Schema
  // مثال: { "days": [{ "day": "Sunday", "exercises": [...] }] }
  details    Json

  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  // Relation: WorkoutPlan belongs to one User
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("workout_plans")
}
